// MACOS KEYBINDS
[
    // GENERAL
  
    {
      "key": "ctrl+space",
      "command": "workbench.action.showCommands"
    },
  
    {
      "key": "tab",
      "command": "selectNextSuggestion",
      "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
  
    {
      "key": "down",
      "command": "-selectNextSuggestion",
      "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
  
    {
      "key": "shift+tab",
      "command": "selectPrevSuggestion",
      "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
  
    {
      "key": "up",
      "command": "-selectPrevSuggestion",
      "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
  
    // HTML
  
    {
      "key": "ctrl+h a 2",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "HTML Center Align"
      }
    },
  
    {
        "key": "ctrl+h i",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus",
        "args": {
          "name": "HTML Image Insert"
        }
    },
  
    {
        "key": "ctrl+h l",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus",
        "args": {
          "name": "HTML Link Insert"
        }
    },
  
    {
      "key": "ctrl+h f",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "HTML Figure"
      }
    },
  
    // Markdown
  
    {
      "key": "ctrl+m ctrl+m",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "Markdown Math"
      }
    },
  
    {
      "key": "ctrl+m m",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "Markdown Math"
      }
    },
  
    {
      "key": "ctrl+m ctrl+m",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "Markdown MATLAB/Octave Code"
      }
    },
  
    // TeX
    {
      "key": "ctrl+t ctrl+w",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "TeX Superscript"
      }
    },
  
    {
      "key": "ctrl+t ctrl+s",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "TeX Subscript"
      }
    },
  
    {
      "key": "ctrl+t i",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "TeX Italic"
      }
    },
  
    {
      "key": "ctrl+t b",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "TeX Bold"
      }
    },
  
    {
      "key": "ctrl+t ctrl+c",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus",
      "args": {
        "name": "TeX Comment"
      }
    }
]